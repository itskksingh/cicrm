generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector(schema: "public")]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  onboardingComplete Boolean @default(false)
  disabled  Boolean  @default(false)
  createdAt DateTime @default(now())

  staff           Staff[]
  users           User[]
  leads           Lead[]
  messages        Message[]
  callLogs        CallLog[]
  knowledgeChunks KnowledgeChunk[]
  doctors         Doctor[]
  settings          Settings[]
  whatsappNumbers   WhatsAppNumber[]
  whatsappCredential WhatsAppCredential?

  @@map("organizations")
}

/// Hospital staff member who uses the CRM dashboard
model Staff {
  id         String    @id @default(uuid())
  name       String
  phone      String    @unique
  email      String?   @unique
  role       Role      @default(CALLER)
  department String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  callLogs   CallLog[]
  leads      Lead[]    @relation("AssignedLeads")
  
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@map("staff")
}

/// A patient lead generated from WhatsApp/Facebook Ads
model Lead {
  id           String     @id @default(uuid())
  name         String?
  phone        String
  age          Int?
  problem      String
  department   String
  priority     Priority   @default(COLD)
  status       LeadStatus @default(NEW)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  notes        String?
  aiSummary    String?
  aiConfidence Float?
  lastMessageAt DateTime   @default(now())
  lastInteraction DateTime @default(now())
  followUpStage   Int      @default(0)
  lastFollowUpAt  DateTime?
  lastCallAt    DateTime?
  callAttempts  Int        @default(0)
  assignedToId  String?
  callLogs     CallLog[]
  assignedTo   Staff?     @relation("AssignedLeads", fields: [assignedToId], references: [id])
  messages     Message[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@map("leads")
}

/// A single message in the WhatsApp chat history for a lead
model Message {
  id        String   @id @default(uuid())
  messageId String?  @unique
  content   String
  sender    Sender
  timestamp DateTime @default(now())
  isRead    Boolean  @default(false)
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@map("messages")
}

/// A log entry for every call made to a patient
model CallLog {
  id        String      @id @default(uuid())
  duration  Int
  outcome   CallOutcome
  notes     String?
  createdAt DateTime    @default(now())
  leadId    String
  staffId   String
  lead      Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  staff     Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@map("call_logs")
}

enum Role {
  ADMIN
  CALLER
}

enum Priority {
  HOT
  WARM
  COLD
}

enum LeadStatus {
  NEW
  ASSIGNED
  ENGAGED
  BOOKED
  VISITED
  CLOSED
}

enum Sender {
  USER
  BOT
  STAFF
}

enum CallOutcome {
  CONVERTED
  FOLLOW_UP
  NOT_INTERESTED
}

/// A chunk of hospital knowledge used for AI RAG
model KnowledgeChunk {
  id         String   @id @default(uuid())
  department String
  content    String
  metadata   Json?
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@map("knowledge_chunks")
}

model Doctor {
  id             String        @id @default(uuid())
  name           String
  department     String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("doctors")
}

model Settings {
  id             String        @id @default(uuid())
  key            String
  value          String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, key])
  @@map("settings")
}

model User {
  id             String        @id @default(uuid())
  email          String?       @unique
  password       String?
  phone          String?       @unique
  /// 'super_admin' | 'admin' | 'staff'
  role           String        @default("staff")
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("users")
}

/// Maps a WhatsApp Business phone number to an organization for multi-tenant webhook routing
model WhatsAppNumber {
  id             String       @id @default(uuid())
  /// E.164 normalized format e.g. +919876543210
  phoneNumber    String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("whatsapp_numbers")
}

/// Stores per-organization WhatsApp API credentials
model WhatsAppCredential {
  id                String       @id @default(uuid())
  organizationId    String       @unique
  organization      Organization @relation(fields: [organizationId], references: [id])
  phoneNumberId     String
  accessToken       String
  businessAccountId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  lastSuccessAt     DateTime?
  lastFailureAt     DateTime?
  failureCount      Int          @default(0)

  @@map("whatsapp_credentials")
}
